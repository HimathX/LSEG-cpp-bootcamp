## Ignore build artifacts and editor temp files

# Compiled object files
*.o
*.obj

# Assembly/source output
*.s

# Executables
*.exe
*.out
*.app

# Compiled dynamic libraries
*.so
*.dylib
*.dll

# Compiled static libraries
*.a
*.lib

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Visual Studio
*.vcxproj.user
*.sln.docstates
.vs/
Debug/
Release/
x64/
x86/

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Temporary files
*.swp
*.swo
*~
.DS_Store

# Build directories
build/
bin/
obj/

# Misc
*.log

# Ignore specific learning artefact
modules/Week-02-Basics-and-Performance/codes/main.i
